# Copy to .env and fill in your keys
TICKETMASTER_API_KEY=your_ticketmaster_key_here
EVENTBRITE_TOKEN=your_eventbrite_token_here
OPENAI_API_KEY=your_openai_key_here

# SQLite DB path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./urban_nomad.db

# CORS: comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
